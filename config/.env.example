MONGODB_URI=mongodb://127.0.0.1:27017/charon

# LLM.
# Backward-compatible shared key. The purpose-specific keys below take precedence.
GROQ_API_KEY=
# Compound/planner key. Leave empty to fall back to GROQ_API_KEY.
GROQ_PLANNER_API_KEY=
# Response-writer key. Leave empty to fall back to GROQ_API_KEY.
GROQ_RESPONSE_API_KEY=
GROQ_PLANNER_MODEL=groq/compound
GROQ_RESPONSE_MODEL=qwen/qwen3-32b
LLM_MAX_OUTPUT_TOKENS=384
LLM_MAX_CALL_INPUT_TOKENS=24000
LLM_PLAN_MAX_OUTPUT_TOKENS=4096
LLM_RESPONSE_MAX_OUTPUT_TOKENS=1024
# 0 means no application-level action limit. Model output size remains finite.
LLM_MAX_SEQUENCE_ACTIONS=0
# Long result sets use the deterministic writer to avoid another oversized model call.
LLM_SEQUENCE_RESPONSE_MAX_STEPS=12
LLM_MAX_INPUT_TOKENS=10000
LLM_CONTEXT_TOKEN_BUDGET=6000
LLM_RESPONSE_CONTEXT_TOKEN_BUDGET=1200
LLM_MAX_CONTEXT_MESSAGES=30
LLM_MAX_CONTEXT_POLLS=8
LLM_TOKENS_PER_MINUTE=5200
LLM_REQUESTS_PER_MINUTE=25
LLM_PLANNER_TOKENS_PER_MINUTE=60000
LLM_PLANNER_REQUESTS_PER_MINUTE=25
LLM_RATE_SAFETY_MULTIPLIER=1.35
LLM_MIN_REQUEST_INTERVAL_MS=1750
LLM_RATE_START_FULL=false

# Default: Charon works in every group it joins. DMs are still ignored.
# Set WHATSAPP_GROUP_SCOPE=restricted and provide one id/name to lock it down.
WHATSAPP_GROUP_SCOPE=all
WHATSAPP_GROUP_ID=
WHATSAPP_GROUP_NAME=
WHATSAPP_REPLY_MODE=tag_only
WHATSAPP_HISTORY_LIMIT=200

BOT_TIMEZONE=America/Phoenix
DEFAULT_MEETING_DURATION_MINUTES=180

# Reminders are sent before 24h, 6h, 1h, 10m, 2m, and when the session starts.
REMINDERS_ENABLED=true
REMINDER_LEAD_MINUTES=1440,360,60,10,2,0
REMINDER_CHECK_INTERVAL_MS=60000

# Google Meet link creation. Easiest: use a permanent Meet link.
GOOGLE_MEET_LINK=

# Dynamic Meet API mode, preferred: OAuth your own Google account once.
# Use a Google OAuth client of type "Desktop app".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional fallback; npm run google:auth saves this token in MongoDB.
GOOGLE_OAUTH_REFRESH_TOKEN=

GOOGLE_MEET_ACCESS_TYPE=OPEN
GOOGLE_MEET_ENTRY_POINT_ACCESS=ALL

PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_HEADLESS=true
PUPPETEER_PROTOCOL_TIMEOUT_MS=120000
PUPPETEER_EXTRA_ARGS=
PUPPETEER_SKIP_DOWNLOAD=true
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
